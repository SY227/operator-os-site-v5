# Lead routing
# console | webhook | both
LEADS_PROVIDER=console

# Required when LEADS_PROVIDER=webhook or both
LEADS_WEBHOOK_URL=

# Analytics routing
# console | webhook | both
ANALYTICS_PROVIDER=console

# Required when ANALYTICS_PROVIDER=webhook or both
ANALYTICS_WEBHOOK_URL=

# Server-side analytics console logging (helpful for Vercel logs)
ANALYTICS_CONSOLE_LOGS=true

# Client-side analytics debug logging in browser console
NEXT_PUBLIC_ANALYTICS_DEBUG=false
